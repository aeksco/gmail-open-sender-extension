{
    "manifest_version": 3,
    "name": "Gmail Open Sender In Search",
    "description": "Adds a button to Gmail's message view to open all messages from that sender in search",
    "version": "1.0.0",
    "content_scripts": [
        {
            "matches": ["https://mail.google.com/*"],
            "js": ["js/contentScript.js"],
            "run_at": "document_end"
        }
    ],
    "icons": {
        "16": "icon-16.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "permissions": ["activeTab"]
}
